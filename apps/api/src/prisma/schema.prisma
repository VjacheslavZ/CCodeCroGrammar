generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -- Enums --

enum UserRole {
  STUDENT
  ADMIN
}

enum NativeLanguage {
  RU
  UK
  EN
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum SubscriptionPlatform {
  STRIPE
  APP_STORE
  GOOGLE_PLAY
}

enum Currency {
  EUR
  USD
}

enum ExerciseType {
  SINGULAR_PLURAL
  FLASHCARDS
  MULTIPLE_CHOICE
  FILL_IN_THE_BLANK
}

// -- Models --

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  name             String
  avatarUrl        String?
  role             UserRole       @default(STUDENT)
  nativeLanguage   NativeLanguage @default(EN)
  googleId         String?        @unique
  appleId          String?        @unique
  xpTotal          Int            @default(0)
  currentStreak    Int            @default(0)
  longestStreak    Int            @default(0)
  lastPracticeDate DateTime?
  expoPushToken    String?
  isBlocked        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  subscription     Subscription?
  wordProgress     UserWordProgress[]
  exerciseSessions ExerciseSession[]
  streakLogs       StreakLog[]

  @@map("users")
}

model SubscriptionPlan {
  id                   String   @id @default(uuid())
  name                 String
  intervalMonths       Int      // 1 or 12
  priceEur             Decimal  @db.Decimal(10, 2)
  priceUsd             Decimal  @db.Decimal(10, 2)
  stripePriceIdEur     String?
  stripePriceIdUsd     String?
  rcProductIdIos       String?
  rcProductIdAndroid   String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                    String             @id @default(uuid())
  userId                String             @unique
  planId                String?
  platform              SubscriptionPlatform?
  status                SubscriptionStatus @default(TRIALING)
  currency              Currency           @default(EUR)
  trialStartedAt        DateTime?
  trialEndsAt           DateTime?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  rcOriginalAppUserId   String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan? @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model WebhookEvent {
  id              String   @id @default(uuid())
  source          String   // "stripe" | "revenuecat"
  externalEventId String   @unique
  payload         Json
  createdAt       DateTime @default(now())

  @@map("webhook_events")
}

model Category {
  id        String   @id @default(uuid())
  nameHr    String
  nameRu    String
  nameUk    String
  nameEn    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wordSets WordSet[]

  @@map("categories")
}

model WordSet {
  id         String   @id @default(uuid())
  categoryId String
  nameHr     String
  nameRu     String
  nameUk     String
  nameEn     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category         Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  words            Word[]
  exerciseSessions ExerciseSession[]

  @@map("word_sets")
}

model Word {
  id                  String  @id @default(uuid())
  wordSetId           String
  baseForm            String
  pluralForm          String?
  translationRu       String
  translationUk       String
  translationEn       String
  sentenceHr          String? // sentence with {{BLANK}}
  sentenceBlankAnswer String?
  wrongOptions        Json?   // 3 distractor options

  wordSet          WordSet              @relation(fields: [wordSetId], references: [id], onDelete: Cascade)
  exerciseConfigs  WordExerciseConfig[]
  wordProgress     UserWordProgress[]
  sessionAnswers   SessionAnswer[]

  @@map("words")
}

model WordExerciseConfig {
  id           String       @id @default(uuid())
  wordId       String
  exerciseType ExerciseType

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([wordId, exerciseType])
  @@map("word_exercise_configs")
}

model UserWordProgress {
  id                 String       @id @default(uuid())
  userId             String
  wordId             String
  exerciseType       ExerciseType
  seenInCurrentCycle Boolean      @default(false)
  cycleNumber        Int          @default(1)
  totalAttempts      Int          @default(0)
  correctAttempts    Int          @default(0)
  lastSeenAt         DateTime?
  lastCorrectAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId, exerciseType])
  @@map("user_word_progress")
}

model ExerciseSession {
  id              String       @id @default(uuid())
  userId          String
  exerciseType    ExerciseType
  wordSetId       String
  totalQuestions  Int          @default(0)
  correctAnswers  Int          @default(0)
  xpEarned        Int          @default(0)
  completedAt     DateTime?
  createdAt       DateTime     @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordSet WordSet         @relation(fields: [wordSetId], references: [id], onDelete: Cascade)
  answers SessionAnswer[]

  @@map("exercise_sessions")
}

model SessionAnswer {
  id           String       @id @default(uuid())
  sessionId    String
  wordId       String
  exerciseType ExerciseType
  givenAnswer  String
  isCorrect    Boolean
  createdAt    DateTime     @default(now())

  session ExerciseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  word    Word            @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@map("session_answers")
}

model StreakLog {
  id       String   @id @default(uuid())
  userId   String
  date     DateTime @db.Date
  xpEarned Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("streak_logs")
}
